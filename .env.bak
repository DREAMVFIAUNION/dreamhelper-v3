# ═══════════════════════════════════════════════════════════
# 梦帮小助 v4.0 · 环境变量配置 (本地优先)
# DREAMVFIA AI Assistant
#
# 用法: 复制为 .env 并填写 LLM API Key (至少一个)
#       其余变量均有合理默认值，无需修改即可启动
# ═══════════════════════════════════════════════════════════

# ── 通用 ──────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug

# ── 数据库 ────────────────────────────────────────────────
DATABASE_URL=postgresql://dreamhelp:dev_password@127.0.0.1:5432/dreamhelp
DATABASE_READ_URL=postgresql://dreamhelp:dev_password@127.0.0.1:5432/dreamhelp

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Milvus 向量库 ────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ── Elasticsearch ─────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ── MinIO 对象存储 ────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# ── LLM 提供商 (至少填一个) ─────────────────────────────
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
QWEN_API_KEY=
# QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
GLM_API_KEY=
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
KIMI_API_KEY=
# KIMI_BASE_URL=https://api.moonshot.cn/v1

# ── NVIDIA NIM (免费无限量) ────────────────────────────
NVIDIA_API_KEY=
# NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# ── Visual Cortex (视觉皮层 — 图片/文档理解) ──────────
VISUAL_CORTEX_ENABLED=true
VISUAL_CORTEX_MODEL=nvidia/nemotron-nano-12b-v2-vl

# ── Hippocampus (海马体 — 1M上下文超长记忆) ──────────
HIPPOCAMPUS_ENABLED=false
HIPPOCAMPUS_MODEL=nvidia/nemotron-3-nano-30b-a3b

# ── Consciousness Core (意识核 — 自主思维引擎) ────────
CONSCIOUSNESS_ENABLED=true
CONSCIOUSNESS_MODEL=nvidia/nemotron-3-nano-30b-a3b
CONSCIOUSNESS_WORLD_MODEL=nvidia/cosmos-reason2-8b
CONSCIOUSNESS_THINK_INTERVAL=900

# ── GitNexus Code Intelligence (代码知识图谱) ─────────
GITNEXUS_ENABLED=true
MCP_GITNEXUS=true
GITNEXUS_MCP_CMD=npx
GITNEXUS_MCP_ARGS=-y gitnexus@latest mcp
GITNEXUS_DEFAULT_REPO=

# ── Embedding ──────────────────────────────────────────
EMBEDDING_PROVIDER=minimax
EMBEDDING_DIM=1536

# ── RAG ────────────────────────────────────────────────
RAG_MODE=memory

# ── JWT (本地模式已移除认证，此项仅保留兼容) ──────────────
# JWT_SECRET=dev_jwt_secret_change_me

# ── Brain Core ──────────────────────────────────────────
BRAIN_CORE_URL=http://localhost:8000

# ── 前端 ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Brain Core API Auth ────────────────────────────────
# 生产环境必须设置，开发环境留空可跳过认证
BRAIN_API_KEY=

# ── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_MS=60000

# ── Webhook ─────────────────────────────────────────────
# WEBHOOK_SECRET=

# ── Code Execution ──────────────────────────────────────
CODE_EXEC_TIMEOUT=10
CODE_EXEC_MAX_OUTPUT=5000

# ── 多渠道接入 (Phase 6) ─────────────────────────────────
# Telegram Bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=

# 微信公众号
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_TOKEN=dreamhelp_wechat_token

# 企业微信
WECOM_CORP_ID=
WECOM_SECRET=
WECOM_AGENT_ID=
WECOM_TOKEN=dreamhelp_wecom_token

# ── MCP (Model Context Protocol) 外接工具服务 ──────────
MCP_ENABLED=true
MCP_SEQUENTIAL_THINKING=true
MCP_FILESYSTEM=true
MCP_FILESYSTEM_ALLOWED_DIRS=/tmp/dreamhelp
MCP_MEMORY_GRAPH=true
MCP_FETCH=true
MCP_TIME=true
MCP_GIT=true
MCP_MODELSCOPE=true
# MODELSCOPE_API_TOKEN=
